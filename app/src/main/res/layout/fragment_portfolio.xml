<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/screen_background"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Last Saved Banner -->
        <LinearLayout android:id="@+id/bannerLastSaved"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:background="@drawable/banner_bg" android:orientation="horizontal"
            android:gravity="center_vertical" android:paddingStart="14dp" android:paddingEnd="14dp"
            android:paddingTop="10dp" android:paddingBottom="10dp"
            android:layout_marginBottom="12dp" android:visibility="gone">
            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:text="🕒 " android:textSize="14sp" />
            <TextView android:id="@+id/tvLastSaved" android:layout_width="0dp"
                android:layout_height="wrap_content" android:layout_weight="1"
                android:textColor="@color/total_green_text" android:textSize="12sp" />
            <Button android:id="@+id/btnClearData" android:layout_width="wrap_content"
                android:layout_height="32dp" android:text="Clear" android:textSize="11sp"
                android:textColor="#DC2626" android:background="@drawable/button_clear_bg"
                android:paddingStart="10dp" android:paddingEnd="10dp" />
        </LinearLayout>

        <!-- Personal Details Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="4dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="👤 Personal Details" android:textColor="@color/total_blue_text"
                    android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Date of Birth" android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/etDOB" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="Tap to select date"
                    android:focusable="false" android:clickable="true"
                    android:background="@drawable/input_bg" android:padding="12dp"
                    android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Retirement Age" android:textColor="@color/text_secondary" android:textSize="13sp"
                    android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/etRetirementAge" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="60" android:inputType="number"
                    android:background="@drawable/input_bg" android:padding="12dp"
                    android:textSize="14sp" android:layout_marginBottom="12dp" />

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Target Corpus at Retirement (₹ in future value)"
                    android:textColor="@color/text_secondary" android:textSize="13sp" android:layout_marginBottom="4dp" />
                <EditText android:id="@+id/etTargetCorpus" android:layout_width="match_parent"
                    android:layout_height="wrap_content" android:hint="e.g. 50000000"
                    android:inputType="numberDecimal" android:background="@drawable/input_bg"
                    android:padding="12dp" android:textSize="14sp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Individual Portfolio Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="4dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="💼 Individual Portfolio" android:textColor="@color/total_blue_text"
                    android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Tap name to rename • Add or remove assets freely"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginBottom="10dp" />

                <!-- Column headers -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.8" android:text="Asset"
                        android:textColor="@color/text_muted" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1.8" android:text="Corpus (₹)"
                        android:textColor="@color/text_muted" android:textSize="11sp"
                        android:gravity="end" android:layout_marginEnd="4dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="0.8" android:text="Rate %"
                        android:textColor="@color/text_muted" android:textSize="11sp"
                        android:gravity="center" android:layout_marginEnd="4dp" />
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="" />
                </LinearLayout>

                <!-- Dynamic asset rows -->
                <LinearLayout android:id="@+id/containerAssets"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <!-- Add asset button -->
                <LinearLayout android:id="@+id/btnAddAsset"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/add_row_bg"
                    android:padding="10dp" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ Add asset" android:textColor="@color/total_blue_text"
                        android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <!-- Portfolio total -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="@drawable/total_bar_blue_bg"
                    android:padding="10dp" android:layout_marginTop="8dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Total investments"
                        android:textColor="@color/total_blue_text" android:textSize="12sp" />
                    <TextView android:id="@+id/tvInvestmentsTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0" android:textColor="@color/total_blue_text"
                        android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- HUF Portfolio Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="4dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏛️ HUF Portfolio" android:textColor="@color/total_blue_text"
                    android:textSize="16sp" android:textStyle="bold" android:layout_marginBottom="2dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Enter current corpus and expected annual growth rate %"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginBottom="12dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:text="Asset" android:textColor="@color/text_muted" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2.5" android:text="Corpus (₹)" android:textColor="@color/text_muted"
                        android:textSize="11sp" android:layout_marginEnd="6dp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Rate %" android:textColor="@color/text_muted"
                        android:textSize="11sp" android:gravity="center" />
                </LinearLayout>

                <include android:id="@+id/rowHUFBank"   layout="@layout/asset_row" />
                <include android:id="@+id/rowHUFStocks" layout="@layout/asset_row" />
                <include android:id="@+id/rowHUFMF"     layout="@layout/asset_row" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Debt Section Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="4dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🔴 Liabilities / Debt"
                    android:textColor="#DC2626" android:textSize="16sp" android:textStyle="bold"
                    android:layout_marginBottom="2dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Outstanding balances — entered as negative values automatically"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2.5" android:text="Liability"
                        android:textColor="@color/text_muted" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:text="Amount (₹)"
                        android:textColor="@color/text_muted" android:textSize="11sp" android:gravity="end"
                        android:layout_marginEnd="4dp" />
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="" />
                </LinearLayout>

                <LinearLayout android:id="@+id/containerDebt"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout android:id="@+id/btnAddDebt"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/add_row_red_bg"
                    android:padding="10dp" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ Add liability" android:textColor="#DC2626"
                        android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="@drawable/total_bar_red_bg"
                    android:padding="10dp" android:layout_marginTop="8dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Total liabilities"
                        android:textColor="#DC2626" android:textSize="12sp" />
                    <TextView android:id="@+id/tvDebtTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0" android:textColor="#DC2626"
                        android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Properties Section Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="4dp" android:layout_marginBottom="12dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp">

                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="🏠 Properties"
                    android:textColor="#7C3AED" android:textSize="16sp" android:textStyle="bold"
                    android:layout_marginBottom="2dp" />
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Real estate and other property assets — current market value"
                    android:textColor="@color/text_hint" android:textSize="11sp" android:layout_marginBottom="10dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2.5" android:text="Property"
                        android:textColor="@color/text_muted" android:textSize="11sp" />
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="2" android:text="Value (₹)"
                        android:textColor="@color/text_muted" android:textSize="11sp" android:gravity="end"
                        android:layout_marginEnd="4dp" />
                    <TextView android:layout_width="28dp" android:layout_height="wrap_content" android:text="" />
                </LinearLayout>

                <LinearLayout android:id="@+id/containerProperties"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="vertical" />

                <LinearLayout android:id="@+id/btnAddProperty"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:gravity="center"
                    android:background="@drawable/add_row_purple_bg"
                    android:padding="10dp" android:layout_marginTop="8dp">
                    <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="+ Add property" android:textColor="#7C3AED"
                        android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:background="@drawable/total_bar_purple_bg"
                    android:padding="10dp" android:layout_marginTop="8dp" android:gravity="center_vertical">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Total property value"
                        android:textColor="#7C3AED" android:textSize="12sp" />
                    <TextView android:id="@+id/tvPropertyTotal"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:text="₹0" android:textColor="#7C3AED"
                        android:textSize="13sp" android:textStyle="bold" />
                </LinearLayout>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Net Worth Card -->
        <androidx.cardview.widget.CardView android:layout_width="match_parent"
            android:layout_height="wrap_content" app:cardCornerRadius="12dp"
            app:cardElevation="6dp" android:layout_marginBottom="16dp">
            <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                android:orientation="vertical" android:padding="16dp"
                android:background="@drawable/header_bg">

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="💰 Net Worth Summary"
                    android:textColor="#FFFFFF" android:textSize="15sp" android:textStyle="bold"
                    android:gravity="center" android:layout_marginBottom="14dp" />

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Investments portfolio"
                        android:textColor="#93C5FD" android:textSize="12sp" />
                    <TextView android:id="@+id/tvNWInvestments"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Properties"
                        android:textColor="#93C5FD" android:textSize="12sp" />
                    <TextView android:id="@+id/tvNWProperties"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FFFFFF" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="8dp">
                    <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                        android:layout_weight="1" android:text="Total liabilities"
                        android:textColor="#93C5FD" android:textSize="12sp" />
                    <TextView android:id="@+id/tvNWLiabilities"
                        android:layout_width="wrap_content" android:layout_height="wrap_content"
                        android:textColor="#FCA5A5" android:textSize="12sp" android:textStyle="bold" />
                </LinearLayout>

                <View android:layout_width="match_parent" android:layout_height="1dp"
                    android:background="#4B72C4" android:layout_marginBottom="10dp" />

                <TextView android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="Your Net Worth" android:textColor="#BFDBFE"
                    android:textSize="12sp" android:gravity="center" android:layout_marginBottom="4dp" />

                <TextView android:id="@+id/tvNetWorth"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:text="₹0" android:textColor="#FFFFFF"
                    android:textSize="32sp" android:textStyle="bold" android:gravity="center" />

                <TextView android:id="@+id/tvNetWorthNote"
                    android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:textColor="#BFDBFE" android:textSize="10sp"
                    android:gravity="center" android:layout_marginTop="4dp" />
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Save Snapshot button - inside Net Worth card, add after tvNetWorthNote -->
        <!-- Action Buttons -->
        <Button android:id="@+id/btnCalculate" android:layout_width="match_parent"
            android:layout_height="56dp" android:text="Calculate Monthly Contribution"
            android:textSize="16sp" android:textStyle="bold" android:background="@drawable/button_bg"
            android:textColor="#FFFFFF" android:layout_marginBottom="10dp" />

        <!-- Save Snapshot -->
        <Button android:id="@+id/btnSaveSnapshot"
            android:layout_width="match_parent" android:layout_height="52dp"
            android:text="📸  Save Net Worth Snapshot"
            android:textSize="14sp" android:textStyle="bold"
            android:background="@drawable/button_snapshot_bg"
            android:textColor="#FFFFFF" android:layout_marginBottom="10dp" />

        <!-- History + Backup row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="10dp">
            <Button android:id="@+id/btnViewHistory"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="📈 Net Worth History"
                android:textSize="12sp" android:background="@drawable/button_secondary_bg"
                android:textColor="@color/total_blue_text" android:layout_marginEnd="6dp" />
            <Button android:id="@+id/btnBackup"
                android:layout_width="0dp" android:layout_height="48dp" android:layout_weight="1"
                android:text="💾 Backup / Restore"
                android:textSize="12sp" android:background="@drawable/button_secondary_bg"
                android:textColor="@color/total_blue_text" android:layout_marginStart="6dp" />
        </LinearLayout>

    </LinearLayout>
</ScrollView>
