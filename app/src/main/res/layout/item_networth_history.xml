<?xml version="1.0" encoding="utf-8"?>
<androidx.cardview.widget.CardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    app:cardCornerRadius="10dp"
    app:cardElevation="3dp"
    android:layout_marginBottom="10dp">

    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="vertical" android:padding="14dp"
        android:background="@color/card_background">

        <!-- Date + trend row -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center_vertical"
            android:layout_marginBottom="8dp">
            <TextView android:id="@+id/tvHistoryDate"
                android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:textColor="@color/text_muted"
                android:textSize="11sp" />
            <TextView android:id="@+id/tvHistoryTrend"
                android:layout_width="wrap_content" android:layout_height="wrap_content"
                android:textSize="12sp" android:textStyle="bold"
                android:paddingStart="8dp" android:paddingEnd="8dp"
                android:paddingTop="3dp" android:paddingBottom="3dp"
                android:background="@drawable/trend_badge_bg"
                android:textColor="#FFFFFF" />
        </LinearLayout>

        <!-- Net Worth big number -->
        <TextView android:id="@+id/tvHistoryNetWorth"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textSize="24sp" android:textStyle="bold"
            android:textColor="@color/text_primary" android:layout_marginBottom="8dp" />

        <!-- Breakdown -->
        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider" android:layout_marginBottom="8dp" />

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal">
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Investments" android:textColor="@color/text_muted" android:textSize="10sp" />
                <TextView android:id="@+id/tvHistoryInvestments"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#1E40AF" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Properties" android:textColor="@color/text_muted" android:textSize="10sp" />
                <TextView android:id="@+id/tvHistoryProperties"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#7C3AED" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
            <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:orientation="vertical">
                <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:text="Liabilities" android:textColor="@color/text_muted" android:textSize="10sp" />
                <TextView android:id="@+id/tvHistoryLiabilities"
                    android:layout_width="wrap_content" android:layout_height="wrap_content"
                    android:textColor="#DC2626" android:textSize="12sp" android:textStyle="bold" />
            </LinearLayout>
        </LinearLayout>
    </LinearLayout>
</androidx.cardview.widget.CardView>
